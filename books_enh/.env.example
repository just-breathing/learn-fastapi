DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD].[SUPABASAE_PROJECT_URL]:5432/postgres

# LLM Chat Settings
LLM_PROVIDER=openrouter      # openrouter | openai | anthropic | google
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=sk-or-v1-your-openrouter-key-here
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=60

# Conversation Context Settings
CONTEXT_WINDOW_SIZE=20           # Number of recent messages to keep in context
SUMMARIZATION_THRESHOLD=15       # Auto-summarize after every N messages
SUMMARY_MODEL=openai/gpt-4o-mini # Model used for summarization